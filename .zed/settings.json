{
  "format_on_save": "on",
  "languages": {
    "Ruby": {
      "tab_size": 2,
      "preferred_line_length": 120,
      "format_on_save": "on",
      "formatter": "language_server",
      "language_servers": [
        "ruby-lsp",
        "rubocop",
        "!solargraph",
        "!sorbet",
        "!steep",
        "!kanayago",
        "!fuzzy-ruby-server",
        "..."
      ],
      "code_actions_on_format": {
        "source.fixAll.rubocop": true
      }
    }
  },
  "lsp": {
    "ruby-lsp": {
      "settings": {
        "use_bundler": true
      }
    },
    "rubocop": {
      "initialization_options": {
        "lintMode": "on",
        "layoutMode": "on"
      }
    }
  }
}
