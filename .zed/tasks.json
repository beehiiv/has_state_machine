[
  {
    "label": "RSpec $ZED_RELATIVE_FILE:$ZED_ROW",
    "command": "bundle",
    "args": ["exec", "rspec", "$ZED_RELATIVE_FILE:$ZED_ROW"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["ruby-test"],
    "save": "all",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "RSpec file $ZED_RELATIVE_FILE",
    "command": "bundle",
    "args": ["exec", "rspec", "$ZED_RELATIVE_FILE"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["ruby-test"],
    "save": "all"
  },
  {
    "label": "RuboCop file $ZED_RELATIVE_FILE",
    "command": "bundle",
    "args": ["exec", "rubocop", "-A", "$ZED_RELATIVE_FILE"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["ruby-test"],
    "save": "all"
  }
]
